#include <stdio.h>

int factorial(int n)
{
    if(n==0||n==1)
       return 1;
    else
       return n*factorial(n-1);
}

int main()
{ int n,f;
printf("Enter a number:");
scanf("%d",&n);
f=factorial(n);
printf("Factorial of %d is %d",n,f);
    return 0;
}
